# ==============================================================================
# U dead?? - Environment Configuration Template
# ==============================================================================

# API Configuration
API_URL=http://localhost:3000/api/v1

# OAuth Credentials
GOOGLE_CLIENT_ID_IOS=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.YOUR_IOS_CLIENT_ID

# Expo Configuration
EXPO_PROJECT_ID=your-project-id

# How often to poll /status endpoint (default: 30 seconds)
STATUS_POLL_INTERVAL=30000

# How long user must hold check-in button (default: 1.5 seconds)
LONG_PRESS_DURATION=1500

# When to send notification warnings before deadline
NOTIFICATION_12H_WARNING=43200000
NOTIFICATION_1H_WARNING=3600000

# Set to 'true' to use mock authentication (for development with fake backend)
ENABLE_MOCK_AUTH=true

# Legal & Privacy Links
PRIVACY_POLICY_URL=https://example.com/privacy
TERMS_URL=https://example.com/terms
